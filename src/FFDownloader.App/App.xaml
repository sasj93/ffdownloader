<Application x:Class="FFDownloader.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#070B16" />
        <SolidColorBrush x:Key="PanelBg" Color="#0D1424" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#243047" />
        <SolidColorBrush x:Key="TextMain" Color="#E5EDF7" />
        <SolidColorBrush x:Key="TextMuted" Color="#8EA0B8" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#182235" />
            <Setter Property="Foreground" Value="#E5EDF7" />
            <Setter Property="BorderBrush" Value="#2A3A55" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E5EDF7" />
            <Setter Property="BorderBrush" Value="#243047" />
            <Setter Property="CaretBrush" Value="#22D3EE" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5EDF7" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#E5EDF7" />
            <Setter Property="BorderBrush" Value="#243047" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1E293B" />
            <Setter Property="RowBackground" Value="#0F172A" />
            <Setter Property="AlternatingRowBackground" Value="#111C2F" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="Foreground" Value="#8EA0B8" />
            <Setter Property="BorderBrush" Value="#243047" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#22D3EE" />
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Height" Value="8" />
        </Style>
    </Application.Resources>
</Application>
