<Window x:Class="FFDownloader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFDOWNLOADER"
        Height="780"
        Width="1280"
        MinHeight="680"
        MinWidth="1080"
        Background="{StaticResource AppBg}"
        Foreground="{StaticResource TextMain}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#070B16" BorderBrush="#162033" BorderThickness="0,0,1,0">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="FFDOWNLOADER" FontSize="21" FontWeight="Bold" />
                    <TextBlock Text="portable download manager" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,26" />

                    <TextBlock Text="DOWNLOADS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" />
                    <Border Background="#111827" CornerRadius="6" Margin="0,8,0,10" Padding="10">
                        <TextBlock Text="{Binding Packages.Count, StringFormat={}{0} pacote(s)}" />
                    </Border>
                    <TextBlock Text="Link Grabber" Foreground="#22D3EE" Margin="0,4,0,0" />
                    <TextBlock Text="Packages" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" />
                    <TextBlock Text="Settings" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Status" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="+ Links" Command="{Binding AddLinksCommand}" />
                        <Button Content="Start" Command="{Binding StartCommand}" />
                        <Button Content="Pause" Command="{Binding PauseCommand}" />
                        <Button Content="Remove" Command="{Binding RemoveSelectedCommand}" />
                        <Button Content="Open folder" Command="{Binding OpenDestinationCommand}" />
                        <Button Content="Clear completed" Command="{Binding ClearCompletedCommand}" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Pacotes" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Packages}"
                              SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                              IsReadOnly="True"
                              AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pacote" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Arquivos" Binding="{Binding FileCount}" Width="80" />
                            <DataGridTextColumn Header="Baixado" Binding="{Binding DownloadedText}" Width="100" />
                            <DataGridTextColumn Header="Tamanho" Binding="{Binding TotalSizeText}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="130" />
                            <DataGridTemplateColumn Header="Progresso" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" />
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0}%}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Destino" Binding="{Binding DestinationFolder}" Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Arquivos do pacote" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SelectedPackage.Items}"
                              IsReadOnly="True"
                              AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding PartNumber}" Width="55" />
                            <DataGridTextColumn Header="Arquivo" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="105" />
                            <DataGridTextColumn Header="Baixado" Binding="{Binding DownloadedText}" Width="100" />
                            <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeText}" Width="100" />
                            <DataGridTextColumn Header="Velocidade" Binding="{Binding SpeedText}" Width="110" />
                            <DataGridTemplateColumn Header="%" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Erro" Binding="{Binding ErrorMessage}" Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="{StaticResource PanelBg}" BorderBrush="#162033" BorderThickness="1,0,0,0" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Detalhes" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedPackage.Name, TargetNullValue=Nenhum pacote selecionado}" Foreground="{StaticResource TextMuted}" Margin="0,4,0,16" TextWrapping="Wrap" />

                    <TextBlock Text="Senha do arquivo" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding SelectedPackage.Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                    <CheckBox Content="Extrair este pacote automaticamente" IsChecked="{Binding SelectedPackage.AutoExtract}" />

                    <TextBlock Text="Destino do pacote" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,18,0,0" />
                    <TextBox Text="{Binding SelectedPackage.DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,20" />

                    <Border Height="1" Background="#243047" Margin="0,8,0,18" />

                    <TextBlock Text="Configuracoes globais" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Pasta padrao" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,14,0,0" />
                    <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <TextBlock Text="Downloads simultaneos" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <TextBlock Text="Conexoes por arquivo" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding ConnectionsPerFile, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <TextBlock Text="Tamanho minimo para multi-conexao (MB)" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding MinMultiConnectionSizeMegabytes, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <TextBlock Text="Tentativas por link" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <TextBlock Text="Limite de velocidade (KB/s, 0 = ilimitado)" Foreground="{StaticResource TextMuted}" FontSize="12" />
                    <TextBox Text="{Binding SpeedLimitKilobytesPerSecond, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />

                    <CheckBox Content="Usar multiplas conexoes por arquivo" IsChecked="{Binding EnableMultiConnectionDownloads}" />
                    <CheckBox Content="Ajustar conexoes automaticamente" IsChecked="{Binding EnableAdaptiveConnectionCount}" />
                    <CheckBox Content="Usar arquivo temporario .ffdownload" IsChecked="{Binding UseTemporaryDownloadFiles}" />
                    <CheckBox Content="Validar identidade remota ao retomar" IsChecked="{Binding ValidateRemoteIdentity}" />
                    <CheckBox Content="Renovar URL expirada automaticamente" IsChecked="{Binding RenewExpiredLinks}" />
                    <CheckBox Content="Monitorar clipboard" IsChecked="{Binding MonitorClipboard}" />
                    <CheckBox Content="Iniciar automaticamente apos adicionar links" IsChecked="{Binding AutoStart}" />
                    <CheckBox Content="Extrair automaticamente" IsChecked="{Binding AutoExtract}" />
                    <CheckBox Content="Criar subpasta por pacote" IsChecked="{Binding CreateSubfolderPerPackage}" />

                    <Button Content="Salvar configuracoes" Command="{Binding SaveSettingsCommand}" Margin="0,18,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
