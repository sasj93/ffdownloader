<Window x:Class="FFDownloader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFDOWNLOADER"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextMain}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="Add links..." Command="{Binding AddLinksCommand}" />
                <MenuItem Header="Open download folder" Command="{Binding OpenDestinationCommand}" />
                <Separator />
                <MenuItem Header="Save settings" Command="{Binding SaveSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="_Downloads">
                <MenuItem Header="Start queue" Command="{Binding StartCommand}" />
                <MenuItem Header="Pause queue" Command="{Binding PauseCommand}" />
                <MenuItem Header="Retry failed" Command="{Binding RetryFailedCommand}" />
                <MenuItem Header="Clear completed" Command="{Binding ClearCompletedCommand}" />
            </MenuItem>
            <MenuItem Header="_Package">
                <MenuItem Header="Open package folder"
                          Command="{Binding OpenPackageFolderCommand}"
                          CommandParameter="{Binding SelectedPackage}" />
                <MenuItem Header="Remove selected package" Command="{Binding RemoveSelectedCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Monitor clipboard" IsCheckable="True" IsChecked="{Binding MonitorClipboard}" />
                <MenuItem Header="Auto start after adding" IsCheckable="True" IsChecked="{Binding AutoStart}" />
                <MenuItem Header="Auto extract completed archives" IsCheckable="True" IsChecked="{Binding AutoExtract}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="FFDOWNLOADER" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="8,7">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Command="{Binding AddLinksCommand}" Style="{StaticResource ToolbarPrimaryButton}">
                        <StackPanel>
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Add Links" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StartCommand}" Style="{StaticResource ToolbarPrimaryButton}">
                        <StackPanel>
                            <TextBlock Text=">" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Start" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PauseCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel>
                            <TextBlock Text="||" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Pause" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RetryFailedCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel>
                            <TextBlock Text="R" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Retry" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearCompletedCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel>
                            <TextBlock Text="C" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Clear Done" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RemoveSelectedCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel>
                            <TextBlock Text="X" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Remove" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenDestinationCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel>
                            <TextBlock Text="..." FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="Folder" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Queue" Style="{StaticResource MetricLabelText}" />
                            <TextBlock Text="{Binding QueueStatusText}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Speed" Style="{StaticResource MetricLabelText}" />
                            <TextBlock Text="{Binding TotalSpeedText}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Progress" Style="{StaticResource MetricLabelText}" />
                            <TextBlock Text="{Binding OverallProgressText}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="292" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,1,0"
                    Padding="10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="CATEGORIES" Style="{StaticResource MetricLabelText}" Margin="0,0,0,8" />

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="All Downloads" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CompletedText, StringFormat=Completed: {0}}" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Running" />
                                <TextBlock Grid.Column="1" Text="{Binding ActiveDownloads}" FontWeight="SemiBold" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Queued / Paused" />
                                <TextBlock Grid.Column="1" Text="{Binding QueuedFiles}" FontWeight="SemiBold" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Failed" Foreground="{StaticResource DangerBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding FailedFiles}" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Padding="8">
                            <StackPanel>
                                <TextBlock Text="Archive Packages" />
                                <TextBlock Text="RAR / multipart groups" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorder}" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Clipboard" Style="{StaticResource SectionTitleText}" />
                            <CheckBox Content="Monitor links" IsChecked="{Binding MonitorClipboard}" />
                            <CheckBox Content="Start after adding" IsChecked="{Binding AutoStart}" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#D4DEE9" />

            <TabControl Grid.Column="2" Margin="8">
                <TabItem Header="Downloads">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="5" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource CardBorder}"
                                Margin="0,0,0,8"
                                Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Download Queue" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="{Binding TransferSummaryText}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Files" Style="{StaticResource MetricLabelText}" />
                                    <TextBlock Text="{Binding CompletedText}" Style="{StaticResource MetricValueText}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Speed" Style="{StaticResource MetricLabelText}" />
                                    <TextBlock Text="{Binding TotalSpeedText}" Style="{StaticResource MetricValueText}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Overall Progress" Style="{StaticResource MetricLabelText}" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding OverallProgressPercent, Mode=OneWay}"
                                                 Margin="0,7,0,4" />
                                    <TextBlock Text="{Binding OverallProgressText}" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0"
                                           Background="{StaticResource HeaderBrush}"
                                           LastChildFill="True"
                                           Margin="0"
                                           Height="34">
                                    <TextBlock Text="Packages"
                                               Style="{StaticResource SectionTitleText}"
                                               VerticalAlignment="Center"
                                               Margin="10,0" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" Margin="0,3,4,3">
                                        <Button Content="Retry Failed" Command="{Binding RetryFailedCommand}" Style="{StaticResource MiniButton}" />
                                        <Button Content="Clear Completed" Command="{Binding ClearCompletedCommand}" Style="{StaticResource MiniButton}" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="31" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="#E4ECF6"
                                            BorderBrush="#C7D4E4"
                                            BorderThickness="1,1,1,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="250" />
                                                <ColumnDefinition Width="95" />
                                                <ColumnDefinition Width="55" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="85" />
                                                <ColumnDefinition Width="125" />
                                                <ColumnDefinition Width="*" MinWidth="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="Package / Filename" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="Status" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="3" Text="Files" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="4" Text="Downloaded" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="5" Text="Size" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="6" Text="Progress" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="7" Text="Save To" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>

                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding Packages}"
                                             SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                                             Background="#FFFFFF"
                                             BorderBrush="{StaticResource BorderBrushSoft}"
                                             BorderThickness="1"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <ContentPresenter />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinWidth="854">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="32" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border x:Name="PackageRow"
                                                            Grid.Row="0"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#E0E7F0"
                                                            BorderThickness="0,0,0,1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="34" />
                                                                <ColumnDefinition Width="250" />
                                                                <ColumnDefinition Width="95" />
                                                                <ColumnDefinition Width="55" />
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="85" />
                                                                <ColumnDefinition Width="125" />
                                                                <ColumnDefinition Width="*" MinWidth="120" />
                                                            </Grid.ColumnDefinitions>

                                                            <ToggleButton Grid.Column="0"
                                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                          Width="22"
                                                                          Height="22"
                                                                          Padding="0"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center">
                                                                <ToggleButton.Style>
                                                                    <Style TargetType="{x:Type ToggleButton}">
                                                                        <Setter Property="Content" Value="+" />
                                                                        <Setter Property="FontWeight" Value="Bold" />
                                                                        <Setter Property="Background" Value="#FFFFFF" />
                                                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                                        <Setter Property="BorderThickness" Value="1" />
                                                                        <Setter Property="Cursor" Value="Hand" />
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter Property="Content" Value="-" />
                                                                                <Setter Property="Background" Value="#EAF4FF" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ToggleButton.Style>
                                                            </ToggleButton>

                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource CellTextBlock}" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="2" Text="{Binding StatusText}" Style="{StaticResource CellTextBlock}" />
                                                            <TextBlock Grid.Column="3" Text="{Binding FileCount}" Style="{StaticResource CellMutedTextBlock}" />
                                                            <TextBlock Grid.Column="4" Text="{Binding DownloadedText}" Style="{StaticResource CellMutedTextBlock}" />
                                                            <TextBlock Grid.Column="5" Text="{Binding TotalSizeText}" Style="{StaticResource CellMutedTextBlock}" />
                                                            <Grid Grid.Column="6" Margin="8,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="42" />
                                                                </Grid.ColumnDefinitions>
                                                                <ProgressBar Minimum="0"
                                                                             Maximum="100"
                                                                             Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                             VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding ProgressPercent, StringFormat={}{0:0}%}"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Right" />
                                                            </Grid>
                                                            <TextBlock Grid.Column="7" Text="{Binding DestinationFolder}" Style="{StaticResource CellMutedTextBlock}" />
                                                        </Grid>
                                                    </Border>

                                                    <Border Grid.Row="1"
                                                            Background="#F7FAFE"
                                                            BorderBrush="#C7D4E4"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="34,6,8,8"
                                                            Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <DataGrid ItemsSource="{Binding Items}"
                                                                  IsReadOnly="True"
                                                                  AlternationCount="2"
                                                                  MaxHeight="220"
                                                                  HeadersVisibility="Column"
                                                                  RowHeight="28"
                                                                  ColumnHeaderHeight="28">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="#" Binding="{Binding PartNumber}" Width="42" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="280" ElementStyle="{StaticResource CellTextBlock}" />
                                                                <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="105" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="92" ElementStyle="{StaticResource CellTextBlock}" />
                                                                <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="92" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="82" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                                <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="82" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                                <DataGridTemplateColumn Header="Progress" Width="120">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ProgressBar Minimum="0"
                                                                                         Maximum="100"
                                                                                         Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                                         Margin="8,0"
                                                                                         VerticalAlignment="Center" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="170" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Border>
                                                </Grid>

                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                                        <Setter TargetName="PackageRow" Property="Background" Value="#EAF4FF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                                        <Setter TargetName="PackageRow" Property="Background" Value="#B9DCF9" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="2"
                                      Height="5"
                                      HorizontalAlignment="Stretch"
                                      Background="#D4DEE9" />

                        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0"
                                           Background="{StaticResource HeaderBrush}"
                                           Height="34">
                                    <TextBlock Text="Files in Selected Package"
                                               Style="{StaticResource SectionTitleText}"
                                               VerticalAlignment="Center"
                                               Margin="10,0" />
                                </DockPanel>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding SelectedPackage.Items}"
                                          IsReadOnly="True"
                                          AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding PartNumber}" Width="42" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="260" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="92" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="85" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="75" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="75" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTemplateColumn Header="%" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ProgressBar Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Margin="8,0"
                                                                 VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="140" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="LinkGrabber">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource CardBorder}"
                                Margin="0,0,0,8">
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="LinkGrabber" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Paste links or let clipboard monitoring collect FuckingFast/Datanodes/MediaFire URLs." Style="{StaticResource MutedText}" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Add New Links" Command="{Binding AddLinksCommand}" Style="{StaticResource PrimaryButton}" />
                                    <Button Content="Start All Downloads" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Background="{StaticResource HeaderBrush}" Height="34">
                                    <TextBlock Text="Collected Packages"
                                               Style="{StaticResource SectionTitleText}"
                                               VerticalAlignment="Center"
                                               Margin="10,0" />
                                </DockPanel>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Packages}"
                                          SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                                          IsReadOnly="True"
                                          AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="70" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding TotalSizeText}" Width="110" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Destination" Binding="{Binding DestinationFolder}" Width="260" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Torrents">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="Torrents" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="{Binding Torrents.StatusMessage}" Style="{StaticResource MutedText}" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Add Magnet" Command="{Binding Torrents.AddMagnetCommand}" Style="{StaticResource PrimaryButton}" />
                                    <Button Content="Add .torrent File" Command="{Binding Torrents.AddTorrentFileCommand}" Style="{StaticResource PrimaryButton}" />
                                    <Button Content="Start" Command="{Binding Torrents.StartCommand}" Style="{StaticResource GhostButton}" />
                                    <Button Content="Pause" Command="{Binding Torrents.PauseCommand}" Style="{StaticResource GhostButton}" />
                                    <Button Content="Remove" Command="{Binding Torrents.RemoveCommand}" Style="{StaticResource DangerButton}" />
                                    <Button Content="Open Folder" Command="{Binding Torrents.OpenFolderCommand}" Style="{StaticResource GhostButton}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Background="{StaticResource HeaderBrush}" Height="34">
                                    <TextBlock Text="Active Torrents"
                                               Style="{StaticResource SectionTitleText}"
                                               VerticalAlignment="Center"
                                               Margin="10,0" />
                                </DockPanel>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Torrents.Torrents}"
                                          SelectedItem="{Binding Torrents.SelectedTorrent, Mode=TwoWay}"
                                          IsReadOnly="True"
                                          AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120" ElementStyle="{StaticResource CellTextBlock}" />
                                        <DataGridTemplateColumn Header="Progress" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="8,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="42" />
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ProgressPercent, StringFormat={}{0:0}%}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="90" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="90" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="DL Speed" Binding="{Binding DownloadSpeedText}" Width="95" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="UL Speed" Binding="{Binding UploadSpeedText}" Width="95" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Seeds" Binding="{Binding Seeds}" Width="60" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Peers" Binding="{Binding Peers}" Width="60" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                        <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="160" ElementStyle="{StaticResource CellMutedTextBlock}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Download Limits" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Simultaneous downloads" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Connections per file" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding ConnectionsPerFile, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Retry count" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Destination" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Default folder" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <DockPanel>
                                        <TextBox Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}" MinWidth="420" />
                                        <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowseDestinationCommand}" Style="{StaticResource MiniButton}" Margin="8,0,0,0" />
                                    </DockPanel>
                                    <CheckBox Content="Create subfolder per package" IsChecked="{Binding CreateSubfolderPerPackage}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Speed" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Speed limit in KB/s" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding SpeedLimitKilobytesPerSecond, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{Binding SpeedLimitSummaryText}" Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                                    <TextBlock Text="Minimum size for multi-connection in MB" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding MinMultiConnectionSizeMegabytes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Automation" Style="{StaticResource SectionTitleText}" />
                                    <CheckBox Content="Use multiple connections per file" IsChecked="{Binding EnableMultiConnectionDownloads}" />
                                    <CheckBox Content="Adjust connections automatically" IsChecked="{Binding EnableAdaptiveConnectionCount}" />
                                    <CheckBox Content="Use .ffdownload temporary files" IsChecked="{Binding UseTemporaryDownloadFiles}" />
                                    <CheckBox Content="Validate remote identity when resuming" IsChecked="{Binding ValidateRemoteIdentity}" />
                                    <CheckBox Content="Renew expired URLs automatically" IsChecked="{Binding RenewExpiredLinks}" />
                                    <CheckBox Content="Monitor clipboard" IsChecked="{Binding MonitorClipboard}" />
                                    <CheckBox Content="Start automatically after adding links" IsChecked="{Binding AutoStart}" />
                                    <CheckBox Content="Extract automatically" IsChecked="{Binding AutoExtract}" />
                                    <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="Torrent Network" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="Listen port" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                    <TextBox Text="{Binding Torrents.ListenPort, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox Content="Enable DHT" IsChecked="{Binding Torrents.EnableDht}" />
                                    <CheckBox Content="Enable Peer Exchange (PEX)" IsChecked="{Binding Torrents.EnablePeerExchange}" />
                                    <CheckBox Content="Enable Local Peer Discovery (LSD)" IsChecked="{Binding Torrents.EnableLocalPeerDiscovery}" />
                                    <CheckBox Content="Enable UPnP / NAT-PMP port forwarding" IsChecked="{Binding Torrents.EnablePortForwarding}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Torrent Speed &amp; Seeding" Style="{StaticResource SectionTitleText}" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Max download KB/s (0 = unlimited)" Style="{StaticResource SectionCaptionText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding Torrents.MaxDownloadSpeedKilobytesPerSecond, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Max upload KB/s (0 = unlimited)" Style="{StaticResource SectionCaptionText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding Torrents.MaxUploadSpeedKilobytesPerSecond, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Default download folder" Style="{StaticResource SectionCaptionText}" Margin="0,12,0,4" />
                                    <DockPanel>
                                        <TextBox Text="{Binding Torrents.DownloadFolder, UpdateSourceTrigger=PropertyChanged}" MinWidth="360" />
                                    </DockPanel>
                                    <CheckBox Content="Stop seeding when ratio/time limit is reached" IsChecked="{Binding Torrents.StopSeedingAtLimit}" Margin="0,12,0,0" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Seed ratio limit (0 = unlimited)" Style="{StaticResource SectionCaptionText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding Torrents.SeedRatioLimit, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Seed time limit, minutes (0 = unlimited)" Style="{StaticResource SectionCaptionText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding Torrents.SeedTimeLimitMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <Button Content="Save Torrent Settings" Command="{Binding Torrents.SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#D4DEE9" />

            <Border Grid.Column="4"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1,0,0,0"
                    Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OVERVIEW" Style="{StaticResource MetricLabelText}" Margin="0,0,0,8" />

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Download Overview" Style="{StaticResource SectionTitleText}" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Packages" />
                                    <TextBlock Grid.Column="1" Text="{Binding PackageCount}" FontWeight="SemiBold" />
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Files" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalFiles}" FontWeight="SemiBold" />
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Failed" />
                                    <TextBlock Grid.Column="1" Text="{Binding FailedFiles}" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OverallProgressPercent, Mode=OneWay}" Margin="0,12,0,4" />
                                <TextBlock Text="{Binding TransferSummaryText}" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Views" Style="{StaticResource SectionTitleText}" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Archives" />
                                    <TextBlock Grid.Column="1" Text="{Binding PackageCount}" />
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Supported hosts" />
                                    <TextBlock Grid.Column="1"
                                               Text="35"
                                               FontWeight="SemiBold"
                                               ToolTip="fuckingfast.co, datanodes.to, mediafire.com, multiup.io/.org, and 31 mirror hosts (gofile.io, krakenfiles.com, megaup.net, ranoz.gg, mixdrop.ag, 1fichier.com, rapidgator.net, nitroflare.com, turbobit.net and more)" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Selected Package" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="{Binding SelectedPackage.Name, TargetNullValue=No package selected}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding SelectedPackage.StatusText, TargetNullValue=-}" Style="{StaticResource MutedText}" Margin="0,2,0,8" />
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding SelectedPackage.ProgressPercent, Mode=OneWay}"
                                             Margin="0,0,0,10" />
                                <TextBlock Text="Package destination" Style="{StaticResource SectionCaptionText}" />
                                <TextBox Text="{Binding SelectedPackage.DestinationFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Browse" Command="{Binding BrowsePackageFolderCommand}" CommandParameter="{Binding SelectedPackage}" Style="{StaticResource MiniButton}" />
                                    <Button Content="Open" Command="{Binding OpenPackageFolderCommand}" CommandParameter="{Binding SelectedPackage}" Style="{StaticResource MiniButton}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Archive Extraction" Style="{StaticResource SectionTitleText}" />
                                <TextBlock Text="Password" Style="{StaticResource SectionCaptionText}" Margin="0,10,0,4" />
                                <TextBox Text="{Binding SelectedPackage.Password, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Extract this package automatically" IsChecked="{Binding SelectedPackage.AutoExtract}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding QueueStatusText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TotalSpeedText, StringFormat=Speed: {0}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding TransferSummaryText}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
