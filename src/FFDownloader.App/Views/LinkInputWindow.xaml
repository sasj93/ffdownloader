<Window x:Class="FFDownloader.App.Views.LinkInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar links"
        Width="720"
        Height="460"
        WindowStartupLocation="CenterOwner"
        Background="#0B1020"
        Foreground="#E5EDF7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Adicionar lista de links" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Cole texto livre: Markdown, bullets, numeracao, links na mesma linha ou URLs sem https://."
                           Foreground="#8EA0B8"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Colar do clipboard" Width="150" Height="34" Click="PasteClipboard_Click" />
        </Grid>

        <TextBox x:Name="LinksBox"
                 Grid.Row="1"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#111827"
                 Foreground="#E5EDF7"
                 BorderBrush="#233044"
                 CaretBrush="#67E8F9"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="12" />

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="DetectedCountText"
                       VerticalAlignment="Center"
                       Foreground="#8EA0B8"
                       Text="0 link(s) detectado(s)" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Width="110" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Adicionar" Width="120" Click="Add_Click" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
