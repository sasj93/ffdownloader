<Window x:Class="FFDownloader.App.Views.LinkInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Links"
        Width="840"
        Height="540"
        MinWidth="720"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextMain}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Analyze and Add Links" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Paste URLs, mixed text, Markdown lists, or FuckingFast/Datanodes/MediaFire links without protocol."
                               Style="{StaticResource MutedText}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#FFFFFF"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="DetectedCountText"
                                   Text="0 link(s) detected"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Button Content="Paste Clipboard"
                            Width="132"
                            Style="{StaticResource PrimaryButton}"
                            Click="PasteClipboard_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="Input"
                           Style="{StaticResource MetricLabelText}"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right"
                           Text="Links are added to the queue only after confirmation."
                           Style="{StaticResource MutedText}" />
            </DockPanel>

            <TextBox x:Name="LinksBox"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     Padding="10" />
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="12">
            <DockPanel>
                <TextBlock Text="FFDOWNLOADER will group multipart archives automatically."
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Cancel"
                            Width="112"
                            Style="{StaticResource GhostButton}"
                            Click="Cancel_Click" />
                    <Button Content="Add"
                            Width="112"
                            Style="{StaticResource PrimaryButton}"
                            Click="Add_Click"
                            IsDefault="True" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
