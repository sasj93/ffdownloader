<Window x:Class="FFDownloader.App.Views.InteractiveBrowserResolverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Complete the download"
        Width="1100"
        Height="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextMain}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <DockPanel>
                <Button x:Name="CancelButton"
                        DockPanel.Dock="Right"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Click="Cancel_Click" />
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               Text="Complete the steps on this page to start your download"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock x:Name="StatusText"
                               Text="Solve any captcha and click the download button. This window closes automatically once the download starts."
                               Style="{StaticResource MutedText}"
                               Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1" />
    </Grid>
</Window>
